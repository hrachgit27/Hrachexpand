<?xml version="1.0" encoding="utf-8"?>
<!-- Full-width row so the bubble can be pushed left or right via gravity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!--
        bubbleContainer gravity is set by MessageAdapter:
          END  for sent messages  (pushed to the right)
          START for received      (pushed to the left)
    -->
    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="270dp">

        <!-- The message bubble text -->
        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/message_bg"
            android:textColor="#000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"/>

        <!-- Time + read-receipt row shown below the bubble -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/messageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#666666"/>

            <!-- ✓ / ✓✓ — only shown on outgoing messages -->
            <TextView
                android:id="@+id/readReceipt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FF4081"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
